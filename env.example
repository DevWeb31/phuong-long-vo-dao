# Template pour le fichier .env.local
# Copiez ce contenu dans un fichier .env.local à la racine du projet

# Environnement actuel (development ou production)
VITE_APP_ENV=development

# Configuration Supabase - Développement
VITE_SUPABASE_URL_DEV=your_supabase_url_dev_here
VITE_SUPABASE_ANON_KEY_DEV=your_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY_DEV=your_service_role_key_here

# Configuration Supabase - Production
VITE_SUPABASE_URL_PROD=your_supabase_url_prod_here
VITE_SUPABASE_ANON_KEY_PROD=your_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY_PROD=your_service_role_key_here

# Instructions :
# 1. Récupérez vos clés depuis l'interface Supabase > Settings > API
# 2. Remplacez "your_*_here" par vos vraies valeurs
# 3. Configurez vos utilisateurs admin dans Supabase > Authentication > Users
# 4. Sauvegardez le fichier comme .env.local à la racine du projet
# 5. NE COMMITEZ JAMAIS le fichier .env.local !
