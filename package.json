{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "node scripts/migrate.js migrate",
    "db:migrate:dev": "node scripts/migrate.js migrate development",
    "db:migrate:prod": "node scripts/migrate.js migrate production",
    "db:seed": "node scripts/migrate.js seed",
    "db:seed:dev": "node scripts/migrate.js seed development",
    "db:seed:prod": "node scripts/migrate.js seed production",
    "db:reset": "node scripts/migrate.js reset development",
    "db:setup": "npm run db:migrate:dev && npm run db:seed:dev",
    "db:deploy": "npm run db:migrate:prod && npm run db:seed:prod",
    "db:create": "node scripts/create-migration.js",
    "db:check": "node scripts/check-config.js",
    "db:guide": "node scripts/setup-guide.js",
    "db:create-tables": "node scripts/create-tables.js",
    "db:create-tables:dev": "VITE_APP_ENV=development node scripts/create-tables.js",
    "db:create-tables:prod": "VITE_APP_ENV=production node scripts/create-tables.js",
    "db:sql": "node scripts/sql-generator.js",
    "db:sql:dev": "VITE_APP_ENV=development node scripts/sql-generator.js",
    "db:sql:prod": "VITE_APP_ENV=production node scripts/sql-generator.js",
    "db:install-tools": "node scripts/install-tools.js",
    "db:auto-create": "node scripts/auto-create-tables.js",
    "db:auto-create:dev": "VITE_APP_ENV=development node scripts/auto-create-tables.js",
    "db:auto-create:prod": "VITE_APP_ENV=production node scripts/auto-create-tables.js",
    "db:api-create": "node scripts/supabase-api-create.js",
    "db:api-create:dev": "VITE_APP_ENV=development node scripts/supabase-api-create.js",
    "db:api-create:prod": "VITE_APP_ENV=production node scripts/supabase-api-create.js",
    "db:final": "node scripts/final-solution.js",
    "db:final:dev": "VITE_APP_ENV=development node scripts/final-solution.js",
    "db:final:prod": "VITE_APP_ENV=production node scripts/final-solution.js",
    "auth:setup": "node scripts/setup-auth.js",
    "auth:setup:dev": "VITE_APP_ENV=development node scripts/setup-auth.js",
    "auth:setup:prod": "VITE_APP_ENV=production node scripts/setup-auth.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.57.4",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.63.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.9.1",
    "recharts": "^3.2.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "yargs": "^18.0.0"
  }
}
